# ============================================================
# DENTAL CLINIC TEMPLATE — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# Brevo (email) — get API key from brevo.com (free tier: 300 emails/day)
BREVO_API_KEY=xkeysib-your-api-key-here

# Google Sheets webhook — paste URL after deploying Apps Script
SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Admin dashboard password
NEXT_PUBLIC_ADMIN_PASSWORD=changeme123

# Optional: Google Analytics 4 ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Site URL (update when deploying to production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Legacy — kept for backward compatibility
RESEND_API_KEY=
ADMIN_EMAIL=
GOOGLE_SHEETS_WEBHOOK_URL=
NEXT_PUBLIC_GOOGLE_SHEET_URL=
CRON_SECRET=
